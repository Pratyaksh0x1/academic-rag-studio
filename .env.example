# LlamaParse API Key (for parsing PDFs into markdown tables and LaTeX)
LLAMA_CLOUD_API_KEY=your_llama_parse_api_key_here

# OpenAI API Key (for Cloud Mode LLM & Embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Tavily API Key (for optional web fallback)
TAVILY_API_KEY=your_tavily_api_key_here

# MongoDB Connection String (for per-user chat history & tenancy)
MONGODB_URI=mongodb://localhost:27017

# JWT Secret Key
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production

# Disable JWT auth for local development (recommended for offline use)
DISABLE_AUTH=true

# App Default Mode: 'local' (Ollama + BGE) or 'cloud' (GPT-4o-mini + OpenAI)
DEFAULT_MODE=local

# Ollama Endpoint
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_REQUEST_TIMEOUT=120

# Retrieval tuning
CONFIDENCE_THRESHOLD_LOCAL=0.35
CONFIDENCE_THRESHOLD_CLOUD=0.55
TOP_K_RETRIEVAL=15
TOP_K_RERANK=5

# Cloud embedding model (small reduces OpenAI quota usage)
CLOUD_EMBEDDING_MODEL=text-embedding-3-small
