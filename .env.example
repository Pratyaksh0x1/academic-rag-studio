# LlamaParse API Key (for parsing PDFs into markdown tables and LaTeX)
LLAMA_CLOUD_API_KEY=your_llama_parse_api_key_here

# OpenAI API Key (for Cloud Mode LLM & Embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Tavily API Key (for Corrective RAG Web Fallback)
TAVILY_API_KEY=your_tavily_api_key_here

# MongoDB Connection String (for per-user chat history & tenancy)
MONGODB_URI=mongodb://localhost:27017

# JWT Secret Key
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production

# App Default Mode: 'local' (Ollama + BGE) or 'cloud' (GPT-4o-mini + OpenAI)
DEFAULT_MODE=local

# Ollama Endpoint (Default local URL)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
